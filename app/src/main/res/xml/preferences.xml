<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
    <PreferenceCategory android:title="@string/settings_category_general_category">
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="@string/pref_key_search_button"
            android:title="@string/pref_show_search_button" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="@string/pref_key_swipe"
            android:title="@string/pref_enable_swipe" />
    </PreferenceCategory>
    <PreferenceCategory android:title="@string/about_header">
        <Preference
            android:key="@string/pref_key_version"
            android:title="@string/about_version_code" />
        <Preference
            android:key="@string/pref_key_source_code"
            android:title="@string/about_project_website" />
    </PreferenceCategory>
</PreferenceScreen>
